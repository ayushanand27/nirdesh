# Copy to .env and fill in. The demo works without this key by falling back
# to the cached extraction in backend/data/cache/ (see extraction.py).
GROQ_API_KEY=

# Model with reliable JSON-mode support on Groq.
GROQ_MODEL=llama-3.3-70b-versatile

# Any extracted rule scoring below this is force-flagged for human review.
CONFIDENCE_REVIEW_THRESHOLD=0.75

# Comma-separated frontend origins in production (Render). Locally, "*" is fine.
# Example: https://nirdesh-frontend.onrender.com
ALLOWED_ORIGINS=*
